\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {Supplementary Figure 10: Prompt diversity analysis.} Box plots showing energy distribution across 5 semantically diverse prompts for (a) text generation (Phi-3, 128 tokens, 128-token runs only) and (b) image generation (SD v1.5, 512$\times $512, 20 steps). Red dashed lines indicate overall means. Maximum between-prompt range is 11.0\% for text and 2.0\% for image, confirming that computational configuration, not prompt content, determines energy consumption.}}{15}{figure.caption.14}\protected@file@percent }
\newlabel{fig:prompt_diversity}{{10}{15}{\textbf {Supplementary Figure 10: Prompt diversity analysis.} Box plots showing energy distribution across 5 semantically diverse prompts for (a) text generation (Phi-3, 128 tokens, 128-token runs only) and (b) image generation (SD v1.5, 512$\times $512, 20 steps). Red dashed lines indicate overall means. Maximum between-prompt range is 11.0\% for text and 2.0\% for image, confirming that computational configuration, not prompt content, determines energy consumption}{figure.caption.14}{}}
