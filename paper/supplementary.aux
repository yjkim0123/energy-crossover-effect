\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Supplementary Table 2: Detailed Crossover Analysis}{12}{subsection.2.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Energy crossover points.} For each modality and platform comparison, we identify adjacent configurations where the Mac-to-GPU energy ratio crosses 1.0 (i.e., where on-device efficiency transitions relative to cloud). Energies are mean values in Joules; the crossover point is linearly interpolated.}}{12}{table.caption.11}\protected@file@percent }
\newlabel{tab:crossover}{{2}{12}{\textbf {Energy crossover points.} For each modality and platform comparison, we identify adjacent configurations where the Mac-to-GPU energy ratio crosses 1.0 (i.e., where on-device efficiency transitions relative to cloud). Energies are mean values in Joules; the crossover point is linearly interpolated}{table.caption.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}Supplementary Table 3: Sensitivity Analysis Results}{12}{subsection.2.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Sensitivity analysis: original vs 40\%-corrected energy ratios.} GPU energy is multiplied by 1.4$\times $ to account for datacenter overhead. The corrected ratio shows that even with this conservative adjustment, on-device inference remains more efficient for small-to-moderate workloads.}}{12}{table.3}\protected@file@percent }
